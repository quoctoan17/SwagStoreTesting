<div class="page-container">
  <div class="page-header">
    <p class="hero-eyebrow">Staff Panel</p>
    <h1 class="page-title">Dashboard</h1>
    <p class="page-subtitle">Welcome back, {{user.name}}. Manage products and place orders for customers.</p>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;margin-bottom:48px;">
    <div class="form-section" style="text-align:center;margin-bottom:0;">
      <div style="font-size:48px;font-family:'Fraunces',serif;font-weight:700;color:var(--accent);">{{productCount}}</div>
      <div style="color:var(--muted);font-size:13px;letter-spacing:.08em;text-transform:uppercase;margin:6px 0 16px;">Products</div>
      <a href="/staff/products" class="btn-primary" style="margin-top:0;padding:10px 20px;font-size:13px;">Manage →</a>
    </div>
    <div class="form-section" style="text-align:center;margin-bottom:0;">
      <div style="font-size:48px;font-family:'Fraunces',serif;font-weight:700;color:var(--success);">{{orderCount}}</div>
      <div style="color:var(--muted);font-size:13px;letter-spacing:.08em;text-transform:uppercase;margin:6px 0 16px;">Orders</div>
      <a href="/staff/orders" class="btn-primary" style="margin-top:0;padding:10px 20px;font-size:13px;">View All →</a>
    </div>
    <div class="form-section" style="text-align:center;margin-bottom:0;">
      <div style="font-size:48px;font-family:'Fraunces',serif;font-weight:700;color:var(--accent2);">${{revenue}}</div>
      <div style="color:var(--muted);font-size:13px;letter-spacing:.08em;text-transform:uppercase;margin:6px 0 16px;">Revenue</div>
      <a href="/staff/orders/new" class="btn-primary" style="margin-top:0;padding:10px 20px;font-size:13px;">New Order →</a>
    </div>
  </div>

  <div class="form-section">
    <div class="form-section-title">Quick Actions</div>
    <div style="display:flex;flex-wrap:wrap;gap:12px;">
      <a href="/staff/products/new" class="btn-primary" style="margin-top:0;">➕ Add Product</a>
      <a href="/staff/orders/new"   class="btn-primary" style="margin-top:0;background:var(--success);">📦 Order for Customer</a>
      <a href="/staff/products"     class="btn-ghost" style="padding:14px 24px;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;">📋 All Products</a>
      <a href="/staff/orders"       class="btn-ghost" style="padding:14px 24px;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;">🧾 All Orders</a>
      <a href="/"                   class="btn-ghost" style="padding:14px 24px;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;">🛍️ Back to Shop</a>
    </div>
  </div>
</div>