<div class="page-container" style="max-width:800px;">
  <div class="page-header">
    <a href="/staff/orders" class="back-link">← Orders</a>
    <h1 class="page-title">Create Order</h1>
    <p class="page-subtitle">Place an order on behalf of a customer.</p>
  </div>

  {{#if error}}
    <div class="alert alert-error" style="margin-bottom:24px;">⚠️ {{error}}</div>
  {{/if}}

  <form action="/staff/orders" method="POST">
    <div class="form-section">
      <div class="form-section-title">👤 Customer</div>
      <div class="form-group">
        <label class="form-label">Select Customer *</label>
        <select name="customerId" class="form-input" required id="customer-select">
          <option value="">— Choose a customer —</option>
          {{#each customers}}
            <option value="{{this.id}}" data-address="{{this.address}}">
              {{this.name}} ({{this.email}})
            </option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Shipping Address</label>
        <input type="text" name="address" id="address-input" class="form-input"
          placeholder="Auto-filled from customer profile, or override here">
      </div>
    </div>

    <div class="form-section">
      <div class="form-section-title">🛍️ Products</div>
      <div id="product-lines">
        <div class="product-line" style="display:grid;grid-template-columns:1fr 100px auto;gap:12px;align-items:end;margin-bottom:12px;">
          <div>
            <label class="form-label">Product *</label>
            <select name="productIds" class="form-input product-select" required>
              <option value="">— Select product —</option>
              {{#each products}}
                <option value="{{this.id}}" data-price="{{this.price}}">{{this.name}} — ${{this.price}}</option>
              {{/each}}
            </select>
          </div>
          <div>
            <label class="form-label">Qty</label>
            <input type="number" name="quantities" class="form-input qty-input" value="1" min="1" style="text-align:center;">
          </div>
          <div style="padding-bottom:2px;">
            <button type="button" onclick="removeLine(this)" class="btn-ghost"
              style="padding:10px 14px;color:var(--danger);border-color:transparent;">✕</button>
          </div>
        </div>
      </div>
      <button type="button" onclick="addLine()" class="btn-ghost"
        style="font-size:13px;padding:10px 18px;color:var(--accent);border-color:var(--accent);">
        ➕ Add Another Product
      </button>
    </div>

    <div class="form-section" id="summary-section" style="display:none;">
      <div class="form-section-title">🧾 Order Summary</div>
      <div id="summary-lines"></div>
      <div class="summary-divider"></div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;">
        <span style="color:var(--muted);font-size:14px;">Subtotal</span>
        <span id="s-subtotal" style="font-size:14px;"></span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;">
        <span style="color:var(--muted);font-size:14px;">Tax (8%)</span>
        <span id="s-tax" style="font-size:14px;"></span>
      </div>
      <div style="display:flex;justify-content:space-between;padding:12px 0;border-top:1px solid var(--border);margin-top:4px;">
        <span style="font-weight:700;">Total</span>
        <span id="s-total" style="font-family:'Fraunces',serif;font-size:22px;font-weight:700;color:var(--accent);"></span>
      </div>
    </div>

    <div style="display:flex;gap:12px;align-items:center;">
      <button type="submit" class="btn-primary" style="margin-top:0;background:var(--success);">📦 Place Order</button>
      <a href="/staff/orders" class="btn-ghost" style="padding:14px 20px;text-decoration:none;display:inline-flex;align-items:center;">Cancel</a>
    </div>
  </form>
</div>

<script>
  document.getElementById('customer-select').addEventListener('change', function () {
    const opt = this.options[this.selectedIndex];
    document.getElementById('address-input').value = opt.dataset.address || '';
  });

  function addLine() {
    const container = document.getElementById('product-lines');
    const first = container.querySelector('.product-line');
    const div = document.createElement('div');
    div.className = 'product-line';
    div.style.cssText = 'display:grid;grid-template-columns:1fr 100px auto;gap:12px;align-items:end;margin-bottom:12px;';
    div.innerHTML = `
      <div>
        <label class="form-label">Product *</label>
        <select name="productIds" class="form-input product-select" required>
          ${first.querySelector('select').innerHTML}
        </select>
      </div>
      <div>
        <label class="form-label">Qty</label>
        <input type="number" name="quantities" class="form-input qty-input" value="1" min="1" style="text-align:center;">
      </div>
      <div style="padding-bottom:2px;">
        <button type="button" onclick="removeLine(this)" class="btn-ghost"
          style="padding:10px 14px;color:var(--danger);border-color:transparent;">✕</button>
      </div>`;
    container.appendChild(div);
    div.querySelectorAll('select, input').forEach(el => el.addEventListener('change', updateSummary));
  }

  function removeLine(btn) {
    if (document.querySelectorAll('.product-line').length <= 1) return;
    btn.closest('.product-line').remove();
    updateSummary();
  }

  function updateSummary() {
    let subtotal = 0;
    let html = '';
    document.querySelectorAll('.product-line').forEach(line => {
      const sel = line.querySelector('select');
      const qty = Number(line.querySelector('.qty-input').value) || 1;
      if (!sel.value) return;
      const price = Number(sel.options[sel.selectedIndex].dataset.price) || 0;
      const sub = +(price * qty).toFixed(2);
      subtotal += sub;
      html += `<div style="display:flex;justify-content:space-between;padding:6px 0;font-size:14px;">
        <span>${sel.options[sel.selectedIndex].text.split(' —')[0]} × ${qty}</span>
        <span>$${sub.toFixed(2)}</span></div>`;
    });
    const tax   = +(subtotal * 0.08).toFixed(2);
    const total = +(subtotal + tax).toFixed(2);
    document.getElementById('summary-section').style.display = subtotal > 0 ? 'block' : 'none';
    document.getElementById('summary-lines').innerHTML = html;
    document.getElementById('s-subtotal').textContent = '$' + subtotal.toFixed(2);
    document.getElementById('s-tax').textContent      = '$' + tax.toFixed(2);
    document.getElementById('s-total').textContent    = '$' + total.toFixed(2);
  }

  document.querySelectorAll('.product-line select, .product-line .qty-input')
    .forEach(el => el.addEventListener('change', updateSummary));
</script>